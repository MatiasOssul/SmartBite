# Copia este archivo a .env y rellena los valores reales (nunca subas .env al repo)

# JWT — genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# Google Gemini API
GOOGLE_API_KEY=

# Pexels API (imágenes)
PEXELS_API_KEY=

# Activar modo mock (no consume API de Gemini)
MOCK_LLM=false

# URL del frontend (para CORS en producción, ej: https://smartbite.onrender.com)
FRONTEND_URL=http://localhost:5173
